/* Last working version: Mozilla Firefox 150.0.1 */

/* Customize about: pages */
@-moz-document url-prefix("about:") {
	:root {
		/* Colors */
		--bg-color: #111111;
		--lighter-bg-color: #1a1a1a;
		--fg-color: __FG__;
		--accent-color: __COL1__;

		/* Customize page colors */
		accent-color: var(--accent-color) !important;
		--color-accent-primary: var(--accent-color) !important;
		--color-accent-primary-hover: var(--accent-color) !important;
		--color-accent-primary-active: var(--accent-color) !important;
		--color-accent-primary-selected: var(--accent-color) !important;

		--background-color-canvas: var(--bg-color) !important;

		--background-color-box: var(--lighter-bg-color) !important;
		--input-text-background-color: var(--lighter-bg-color) !important;
		--background-color-box-info: var(--lighter-bg-color) !important;

		--table-background-color: var(--lighter-bg-color) !important;
		--table-row-background-color: var(--bg-color) !important;
		--table-row-background-color-alternate: var(--lighter-bg-color) !important;
	}

	input, .qr-code-box {
		background-color: var(--lighter-bg-color) !important;
	}
}

/* Customize new tab/home page */
@-moz-document url("about:home"), url("about:newtab"), url("about:privatebrowsing") {
	@font-face {
		font-family: "Diwani Letter";
		src: url("fonts/Diwani-Letter.ttf") format("truetype");
	}

	/*
	@font-face {
		font-family: "Al Diwani Al Majd";
		src: url("fonts/Al-Diwani-Al-Majd.ttf") format("truetype");
	}
	*/

	:root {
		--newtab-background-color: var(--bg-color) !important;
		--newtab-background-card: var(--lighter-bg-color) !important;
		--newtab-wordmark-color: var(--fg-color) !important;
	}

	/* Customize logo */
	.logo-and-wordmark-wrapper, .logo-and-wordmark {
		position: fixed !important;
		top: 15% !important;
		left: 50% !important;
		transform: translateX(-50%) !important;
	}

	.logo {
		width: 75px !important;
		height: 75px !important;

		background-image: none !important;
		background-color: var(--accent-color) !important;

		mask-size: contain;
		mask-repeat: no-repeat;
		mask-position: center;

		mask-image: url('data:image/svg+xml;utf8,<svg fill="currentColor" width="800px" height="800px" viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg"><path fill="currentColor" d="M11.807 9.776c0.011 0 0.005 0 0 0zM8.109 7.927c0.011 0 0.005 0 0 0zM30.229 10.781c-0.667-1.604-2.021-3.333-3.079-3.885 0.865 1.692 1.365 3.396 1.552 4.661l0.005 0.027c-1.739-4.329-4.681-6.073-7.088-9.871-0.12-0.192-0.24-0.385-0.36-0.588-0.063-0.104-0.115-0.208-0.172-0.319-0.099-0.192-0.171-0.395-0.224-0.609 0-0.020-0.015-0.036-0.036-0.041-0.011 0-0.021 0-0.031 0l-0.005 0.005c-0.005 0-0.011 0.005-0.011 0.005s0-0.005 0.005-0.011c-3.417 2-4.828 5.505-5.193 7.729-1.057 0.063-2.088 0.328-3.041 0.776-0.183 0.093-0.265 0.303-0.197 0.489 0.077 0.213 0.317 0.319 0.525 0.224 0.833-0.391 1.729-0.625 2.651-0.687l0.089-0.011c0.125-0.005 0.255-0.011 0.38-0.011 0.745-0.005 1.489 0.099 2.203 0.307l0.125 0.037c0.12 0.036 0.235 0.077 0.355 0.12 0.083 0.031 0.172 0.063 0.255 0.099 0.068 0.025 0.136 0.057 0.203 0.083 0.105 0.048 0.209 0.1 0.313 0.152l0.14 0.067c0.104 0.053 0.204 0.109 0.303 0.167 0.063 0.037 0.125 0.073 0.187 0.115 1.111 0.688 2.037 1.641 2.683 2.776-0.817-0.572-2.287-1.145-3.697-0.895 5.52 2.76 4.036 12.265-3.615 11.905-0.683-0.025-1.355-0.156-1.995-0.385-0.156-0.057-0.308-0.12-0.453-0.183-0.088-0.041-0.177-0.083-0.26-0.124-1.876-0.969-3.423-2.803-3.615-5.027 0 0 0.708-2.64 5.072-2.64 0.475 0 1.824-1.319 1.849-1.699-0.011-0.125-2.683-1.187-3.724-2.213-0.557-0.547-0.817-0.812-1.052-1.011-0.125-0.109-0.26-0.208-0.401-0.301-0.348-1.224-0.364-2.521-0.041-3.751-1.579 0.719-2.803 1.855-3.693 2.855h-0.009c-0.609-0.771-0.563-3.313-0.532-3.844-0.005-0.036-0.453 0.229-0.511 0.271-0.536 0.385-1.041 0.813-1.5 1.287-0.525 0.531-1.004 1.104-1.437 1.719-0.984 1.396-1.687 2.979-2.057 4.645-0.005 0.021-0.145 0.647-0.249 1.417-0.021 0.12-0.037 0.24-0.052 0.359-0.043 0.292-0.073 0.589-0.089 0.881l-0.005 0.047c-0.009 0.172-0.020 0.339-0.031 0.511v0.077c0 8.48 6.875 15.355 15.355 15.355 7.593 0 13.9-5.516 15.135-12.756 0.027-0.197 0.047-0.395 0.068-0.593 0.307-2.631-0.031-5.401-0.995-7.713z"/></svg>') !important;
	}

	.wordmark {
		width: 155px !important;
		background-size: 155px !important;
		fill: var(--fg-color) !important;
	}

	/* Remove search bar */
	.search-inner-wrapper content-search-handoff-ui {
		display: none !important;
	}

	.search-inner-wrapper {
		width: 100% !important;
		padding: 0 !important;
		margin: 0 !important;
		overflow: visible !important;
	}

	/* Dua */
	.search-inner-wrapper::after {
		content: "سُبْحَانَ اللَّهِ وَبِحَمْدِهِ، سُبْحَانَ اللَّهِ الْعَظِيمِ" !important;

		position: fixed !important;
		top: 45% !important;
		left: 50% !important;
		transform: translateX(-50%) !important;

		font-size: 64px !important;
		font-family: "Diwani Letter" !important;
		/* font-family: "Al Diwani Al Majd" !important; */
		text-align: center !important;

		color: var(--fg-color) !important;
	}

	/* Customize top site buttons */
	.top-site-outer .tile {
		background-color: var(--lighter-bg-color) !important;
	}

	.top-site-outer .title {
		color: var(--fg-color) !important;
	}

	/* Hide top sites (above styling just in case) */
	.ds-top-sites {
		display: none !important;
	}

	/* Hide edit button */
	menu.personalizeButtonWrapper {
		display: none !important;
	}
}

@-moz-document url("about:privatebrowsing") {
	.info-border {
		display: none !important;
	}

	.search-inner-wrapper::after {
		content: "يَا مُقَلِّبَ الْقُلُوبِ، ثَبِّتْ قَلْبِي عَلَى دِينِكَ" !important;
		/* content: "اللَّهُمَّ يَا مُقَلِّبَ الْقُلُوبِ، ثَبِّتْ قَلْبِي عَلَى دِينِكَ" !important; */
	}
}

@-moz-document url-prefix("file:///") {
	:root {
		/* Colors */
		--bg-color: #111111;
		--lighter-bg-color: #1a1a1a;
		--fg-color: __FG__;
		--accent-color: __COL1__;

		background-color: var(--bg-color) !important;
	}

	body:has(#UI_showHidden, #UI_goUp) {
		background-color: var(--lighter-bg-color) !important;
		border: 2px solid var(--accent-color) !important;
		border-radius: 4px !important;
		color: var(--fg-color) !important;
		accent-color: var(--accent-color) !important;
	}

	body:has(#UI_showHidden, #UI_goUp) a.dir,
	body:has(#UI_showHidden, #UI_goUp) a.up,
	body:has(#UI_showHidden, #UI_goUp) a.file {
		color: var(--fg-color) !important;
	}

	body:has(#UI_showHidden, #UI_goUp) a.dir:visited {
		color: var(--accent-color) !important;
	}

	/* Change directory icon */
	body:has(#UI_showHidden, #UI_goUp) a.dir::before {
		-moz-context-properties: fill !important;
		fill: var(--accent-color) !important;

		background: url('data:image/svg+xml;utf8,<svg style="width: 1em; height: 1em; fill: context-fill;" viewBox="0 0 1024 1024" version="1.1" xmlns="http://www.w3.org/2000/svg"><path d="M426.666667 170.666667H170.666667c-47.146667 0-84.906667 38.186667-84.906667 85.333333L85.333333 768c0 47.146667 38.186667 85.333333 85.333334 85.333333h682.666666c47.146667 0 85.333333-38.186667 85.333334-85.333333V341.333333c0-47.146667-38.186667-85.333333-85.333334-85.333333H512l-85.333333-85.333333z"/></svg>') !important;

		position: relative !important;
		left: 1px !important;
	}

	body:has(#UI_showHidden, #UI_goUp) td:has(a.dir) {
		position: relative !important;
		left: -1px !important;
	}

	/* Change directory up icon */
	body:has(#UI_showHidden, #UI_goUp) a.up::before {
		-moz-context-properties: fill !important;
		fill: var(--accent-color) !important;

		background: url('data:image/svg+xml;utf8,<svg style="width: 1em; height: 1em; fill: context-fill;" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" clip-rule="evenodd" d="M19.3636 6.63636C20.2674 6.63636 21 7.36899 21 8.27273V18.0909C21 18.9946 20.2674 19.7273 19.3636 19.7273H4.63636C3.73262 19.7273 3 18.9946 3 18.0909V6.63636C3 5.73262 3.73262 5 4.63636 5H9.54545C10.4618 5 11.0451 5.38901 11.631 6.12815C11.6471 6.14854 11.6864 6.19918 11.73 6.25534C11.7917 6.33486 11.8624 6.42596 11.8875 6.45703C11.9129 6.48848 11.9342 6.51449 11.9519 6.53598C12.0239 6.6235 12.0343 6.63619 12.0015 6.63636H19.3636ZM9.2 12.97L8.51 12.28L11.985 8.8L15.46 12.28L14.77 12.97L12.48 10.68V17.2H11.49V10.68Z"/></svg>') !important;
	}

	/* Change PDF file icon */
	img[src^="moz-icon://.pdf"] {
		appearance: none !important;
		display: inline-block !important;
		width: 0 !important;

		height: 14px !important;
		padding-left: 14px !important;

		-moz-context-properties: fill !important;
		fill: var(--accent-color) !important;
		background: url('data:image/svg+xml;utf8,<svg style="width: 1em; height: 1em; fill: context-fill;" viewBox="0 0 15 15" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M3.5 8H3V7H3.5C3.77614 7 4 7.22386 4 7.5C4 7.77614 3.77614 8 3.5 8Z" /><path d="M7 10V7H7.5C7.77614 7 8 7.22386 8 7.5V9.5C8 9.77614 7.77614 10 7.5 10H7Z" /><path fill-rule="evenodd" clip-rule="evenodd" d="M1 1.5C1 0.671573 1.67157 0 2.5 0H10.7071L14 3.29289V13.5C14 14.3284 13.3284 15 12.5 15H2.5C1.67157 15 1 14.3284 1 13.5V1.5ZM3.5 6H2V11H3V9H3.5C4.32843 9 5 8.32843 5 7.5C5 6.67157 4.32843 6 3.5 6ZM7.5 6H6V11H7.5C8.32843 11 9 10.3284 9 9.5V7.5C9 6.67157 8.32843 6 7.5 6ZM10 11V6H13V7H11V8H12V9H11V11H10Z" /></svg>') !important;
		background-size: 14px 14px !important;
	}

	/* Change text file icon */
	img[src^="moz-icon://.txt"] {
		appearance: none !important;
		display: inline-block !important;
		width: 0 !important;

		height: 14px !important;
		padding-left: 14px !important;

		-moz-context-properties: fill !important;
		fill: var(--accent-color) !important;
		background: url('data:image/svg+xml;utf8,<svg style="width: 1em; height: 1em; fill: context-fill;" viewBox="0 0 15 15" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" clip-rule="evenodd" d="M1 1.5C1 0.671573 1.67157 0 2.5 0H10.7071L14 3.29289V13.5C14 14.3284 13.3284 15 12.5 15H2.5C1.67157 15 1 14.3284 1 13.5V1.5Z M3 4.5V3.5H9V4.5H3Z M3 7V6H11V7H3Z M3 9.5V8.5H10V9.5H3Z M3 12V11H12V12H3Z"/></svg>') !important;
		background-size: 14px 14px !important;
	}

	/* Change MD file icon */
	img[src^="moz-icon://.md"] {
		appearance: none !important;
		display: inline-block !important;
		width: 0 !important;

		height: 14px !important;
		padding-left: 14px !important;

		-moz-context-properties: fill !important;
		fill: var(--accent-color) !important;
		background: url('data:image/svg+xml;utf8,<svg style="width: 1em; height: 1em; fill: context-fill;" viewBox="0 0 15 15" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" clip-rule="evenodd" d="M1 1.5C1 0.671573 1.67157 0 2.5 0H10.7071L14 3.29289V13.5C14 14.3284 13.3284 15 12.5 15H2.5C1.67157 15 1 14.3284 1 13.5V1.5ZM3 6V11H4V9L5 11L6 9V11H7V6H6L5 8L4 6H3ZM8 6H10.5C11.3284 6 12 6.67157 12 7.5V9.5C12 10.3284 11.3284 11 10.5 11H8V6ZM9 7V10H10.5C10.7761 10 11 9.7761 11 9.5V7.5C11 7.2239 10.7761 7 10.5 7H9Z"/></svg>') !important;
		background-size: 14px 14px !important;
	}

	/* Change SH file icon */
	img[src^="moz-icon://.sh"] {
		appearance: none !important;
		display: inline-block !important;
		width: 0 !important;

		height: 14px !important;
		padding-left: 14px !important;

		-moz-context-properties: fill !important;
		fill: var(--accent-color) !important;
		background: url('data:image/svg+xml;utf8,<svg style="width: 1em; height: 1em; fill: context-fill;" viewBox="0 0 15 15" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" clip-rule="evenodd" d="M1 1.5C1 0.671573 1.67157 0 2.5 0H10.7071L14 3.29289V13.5C14 14.3284 13.3284 15 12.5 15H2.5C1.67157 15 1 14.3284 1 13.5V1.5ZM3 6.5L6 8.5L3 10.5V9.3L4.2 8.5L3 7.7V6.5ZM7 10.5V9.5H11V10.5H7Z"/></svg>') !important;
		background-size: 14px 14px !important;
	}

