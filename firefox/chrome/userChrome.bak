/* Last working version: Mozilla Firefox 150.0.1 */

/* TODO:
* Style CTRL + F find bar.
*/

@import "fonts.css";

:root {
	/* Colors */
	--bg-color: #111111;
	--lighter-bg-color: #1a1a1a;
	--fg-color: __FG__;
	--accent-color: __COL1__;

	/* Panel customization */
	--panel-background: var(--lighter-bg-color) !important;
	--panel-border-color: var(--bg-color) !important;
	--panel-color: #ffffff !important;

	/* Toolbar button customization */
	--toolbarbutton-hover-background: transparent !important;
	--toolbarbutton-active-background: transparent !important;
	--toolbarbutton-active-outline-color: var(--accent-color) !important;
	--toolbarbutton-icon-fill-attention: var(--accent-color) !important;

	--color-accent-primary: var(--accent-color) !important;
	--border-color-selected: var(--accent-color) !important;

	/* Customize links */
	--link-color: var(--accent-color) !important;
	--link-color-hover: var(--accent-color) !important;
	--link-color-active: var(--accent-color) !important;
}

/* Change font and accent color on all elements */
* {
	font-family: "JetBrainsMono NF" !important;
	accent-color: var(--accent-color) !important;
}

/* Change popup colors */
menupopup, panel {
	--panel-background: var(--lighter-bg-color) !important;
	--panel-border-color: var(--bg-color) !important;
	--panel-color: var(--fg-color) !important;
}

menuitem[_moz-menuactive="true"] {
	background-color: var(--accent-color) !important;
}

#select-translations-panel-text-area {
	outline: none !important;
	border-color: var(--accent-color) !important;
}

/* Change color of close browser confirmation popup */
window#commonDialogWindow {
	background-color: var(--lighter-bg-color) !important;
}

/* Customize buttons */
button[default="true"] {
	border: 2px solid var(--accent-color) !important;
	color: var(--fg-color) !important;
	background: none !important;
}

.toggle-button[aria-pressed="true"] {
	background: none !important;
	border: 1px solid var(--accent-color) !important;

	&::before {
		background-color: var(--accent-color) !important;
	}
}

/* Customize some links (--link-color in :root should be enough but just in case) */
.panel-subview-footer-button {
	color: var(--accent-color) !important;
}

/* Hide all tabs button */
toolbarbutton#alltabs-button {
	display: none !important;
}

/* Hide tab scroll forwards and backwards buttons */
toolbarbutton#scrollbutton-down {
	display: none !important;
}

toolbarbutton#scrollbutton-up .toolbarbutton-icon {
	width: 0px !important;
}

/* Hide browser close button */
toolbarbutton.titlebar-button.titlebar-close {
	display: none !important;
}

/* Hide reader mode button */
#reader-mode-button {
	display: none !important;
}

/* Hide picture-in-picture button */
#picture-in-picture-button {
	display: none !important;
}

/* Move tabs below address bar */
toolbar#TabsToolbar {
	order: 2 !important;
}

/* Bookmark bar customizaton */
toolbar#PersonalToolbar {
	/* Move bookmarks below tabs */
	order: 3 !important;

	/* Change bookmark toolbar colors */
	background-color: var(--bg-color) !important;
	color: var(--fg-color) !important;
	font-weight: 500 !important;

	/* Only show bookmarks when hovered over */
	opacity: 0 !important;
	max-height: 0px !important;
	transition:
		opacity 0.3s ease 1s,
		max-height 0.3s ease 1s !important;
}

toolbar#TabsToolbar:hover ~ toolbar#PersonalToolbar, toolbar#PersonalToolbar:hover {
	opacity: 1 !important;
	max-height: 100px !important;
	transition:
		opacity 0.3s ease 1s,
		max-height 0.3s linear 1s !important;
}

/* Change colors of opened bookmark item (ex.: folder) */
toolbarbutton.bookmark-item[open="true"] {
	color: var(--accent-color) !important;
	border-radius: 4px !important;
	font-weight: 700 !important;
}

/** Customize address bar **/

/* Change icon colors */
toolbarbutton#back-button, toolbarbutton#forward-button,
toolbarbutton#reload-button, toolbarbutton#PanelUI-menu-button,
toolbarbutton#downloads-button, #trust-icon,
#star-button, #translations-button-icon,
#permissions-granted-icon, .blocked-permission-icon,
#urlbar-revert-button {
	fill: var(--fg-color) !important;
}

.tab-throbber {
	color: var(--fg-color) !important;
}

.button-background {
	color: var(--fg-color) !important;
}

/* Change icon colors when open/active (burger menu, refresh) */
#nav-bar .toolbarbutton-1[open="true"] > .toolbarbutton-badge-stack,
.toolbarbutton-animatable-box, toolbarbutton#back-button:active,
toolbarbutton#forward-button:active, toolbarbutton#reload-button:active,
toolbarbutton#stop-button {
	fill: var(--accent-color) !important;
}

#translations-button-locale {
	background-color: var(--accent-color) !important;
}

#urlbar-revert-button:hover {
	background: none !important;
}

toolbarbutton#urlbar-zoom-button {
	color: var(--fg-color) !important;
}

/* Change downloads button color */
#downloads-indicator-icon {
	fill: var(--fg-color) !important;
}

toolbarbutton#downloads-button[attention] #downloads-indicator-icon,
toolbarbutton#downloads-button[downloading] #downloads-indicator-icon,
toolbarbutton#downloads-button[open="true"] #downloads-indicator-icon {
	fill: var(--accent-color) !important;
}

/* Download animations */
#downloads-indicator-finish-image, #downloads-indicator-start-image,
#downloads-indicator-progress-inner, #downloads-indicator-progress-outer {
	fill: var(--accent-color) !important;
}

/* Style normal/hover/active effects of trust icon, permissions box, translation icon, and bookmark icon */
#trust-icon-container, #identity-permission-box, #translations-button, #star-button-box {
	background: none !important;
	outline: none !important;
	border: none !important;
}

#trust-icon-container[open="true"], #trust-icon-container:active,
#identity-permission-box[open="true"], #identity-permission-box:active,
#translations-button[open="true"], #translations-button:active,
#star-button-box[open="true"], #star-button-box:active {
	outline: 1px solid var(--accent-color) !important;
}

#trust-icon-container[open="true"] #trust-icon, #trust-icon-container:active #trust-icon,
#identity-permission-box[open="true"] #permissions-granted-icon, #identity-permission-box:active #permissions-granted-icon,
#identity-permission-box[open="true"] .blocked-permission-icon, #identity-permission-box:active .blocked-permission-icon,
#translations-button[open="true"] #translations-button-icon, #translations-button:active #translations-button-icon,
#star-button-box[open="true"] #star-button, #star-button-box:active #star-button, #star-button[starred] {
	fill: var(--accent-color) !important;
}

/* Hide other search engines button */
.searchmode-switcher {
	display: none !important;
}

/* Change icon of new tab */
.tab-icon-image[src="chrome://branding/content/icon32.png"] {
	-moz-context-properties: fill !important;
	fill: var(--fg-color) !important;
	content: url('data:image/svg+xml;utf8,<svg width="16px" height="16px" viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg"><path fill="context-fill" d="M11.807 9.776c0.011 0 0.005 0 0 0zM8.109 7.927c0.011 0 0.005 0 0 0zM30.229 10.781c-0.667-1.604-2.021-3.333-3.079-3.885 0.865 1.692 1.365 3.396 1.552 4.661l0.005 0.027c-1.739-4.329-4.681-6.073-7.088-9.871-0.12-0.192-0.24-0.385-0.36-0.588-0.063-0.104-0.115-0.208-0.172-0.319-0.099-0.192-0.171-0.395-0.224-0.609 0-0.020-0.015-0.036-0.036-0.041-0.011 0-0.021 0-0.031 0l-0.005 0.005c-0.005 0-0.011 0.005-0.011 0.005s0-0.005 0.005-0.011c-3.417 2-4.828 5.505-5.193 7.729-1.057 0.063-2.088 0.328-3.041 0.776-0.183 0.093-0.265 0.303-0.197 0.489 0.077 0.213 0.317 0.319 0.525 0.224 0.833-0.391 1.729-0.625 2.651-0.687l0.089-0.011c0.125-0.005 0.255-0.011 0.38-0.011 0.745-0.005 1.489 0.099 2.203 0.307l0.125 0.037c0.12 0.036 0.235 0.077 0.355 0.12 0.083 0.031 0.172 0.063 0.255 0.099 0.068 0.025 0.136 0.057 0.203 0.083 0.105 0.048 0.209 0.1 0.313 0.152l0.14 0.067c0.104 0.053 0.204 0.109 0.303 0.167 0.063 0.037 0.125 0.073 0.187 0.115 1.111 0.688 2.037 1.641 2.683 2.776-0.817-0.572-2.287-1.145-3.697-0.895 5.52 2.76 4.036 12.265-3.615 11.905-0.683-0.025-1.355-0.156-1.995-0.385-0.156-0.057-0.308-0.12-0.453-0.183-0.088-0.041-0.177-0.083-0.26-0.124-1.876-0.969-3.423-2.803-3.615-5.027 0 0 0.708-2.64 5.072-2.64 0.475 0 1.824-1.319 1.849-1.699-0.011-0.125-2.683-1.187-3.724-2.213-0.557-0.547-0.817-0.812-1.052-1.011-0.125-0.109-0.26-0.208-0.401-0.301-0.348-1.224-0.364-2.521-0.041-3.751-1.579 0.719-2.803 1.855-3.693 2.855h-0.009c-0.609-0.771-0.563-3.313-0.532-3.844-0.005-0.036-0.453 0.229-0.511 0.271-0.536 0.385-1.041 0.813-1.5 1.287-0.525 0.531-1.004 1.104-1.437 1.719-0.984 1.396-1.687 2.979-2.057 4.645-0.005 0.021-0.145 0.647-0.249 1.417-0.021 0.12-0.037 0.24-0.052 0.359-0.043 0.292-0.073 0.589-0.089 0.881l-0.005 0.047c-0.009 0.172-0.020 0.339-0.031 0.511v0.077c0 8.48 6.875 15.355 15.355 15.355 7.593 0 13.9-5.516 15.135-12.756 0.027-0.197 0.047-0.395 0.068-0.593 0.307-2.631-0.031-5.401-0.995-7.713z"/></svg>') !important;
	width: 16px !important;
	height: 16px !important;
}

.tabbrowser-tab[selected] .tab-icon-image[src="chrome://branding/content/icon32.png"] {
	fill: var(--accent-color) !important;
}

/* Add more space between tab icon and label */
.tab-icon-image, .tab-throbber {
	margin-inline-end: 8px !important;
}

/* Improve tab icon vertical alignment */
.tab-icon-image:not([src="chrome://branding/content/icon32.png"]) {
	margin-block-end: -1px !important;
}

/* Hide tab close button */
.tab-close-button {
	display: none !important;
}

/* Hide new tab button */
/*
toolbarbutton#new-tab-button {
	display: none !important;
}

toolbarbutton#tabs-newtab-button {
	display: none !important;
}
*/

/* _Or_ customize new tab button */
toolbarbutton#new-tab-button:active {
	fill: var(--accent-color) !important;
}

toolbarbutton#tabs-newtab-button:active {
	fill: var(--accent-color) !important;
}

/* Toolbar background */
#nav-bar, #TabsToolbar {
	background: var(--bg-color) !important;
	border: none !important;
	box-shadow: none !important;
}

/* URL bar background (including search suggestions) */
.urlbar-background {
	background: var(--bg-color) !important;
	border: none !important;
	outline: none !important;
}

#urlbar[focused] > .urlbar-background {
	background: var(--lighter-bg-color) !important;
}

.urlbarView-body-inner {
	border-top: 2px solid var(--accent-color) !important;
}

.urlbarView-url {
	color: var(--fg-color) !important;
}

#urlbar-input {
	font-weight: bold !important;
	padding-left: 5px !important;
	padding-right: 0px !important;
}

/* Tab preview */
.tab-preview-content-main {
	background: var(--lighter-bg-color) !important;
	border: 1px solid var(--bg-color) !important;
}

.tab-preview-thumbnail-container {
	& > canvas{
		border: 1px solid var(--bg-color) !important;
	}
}

/* Center tab content */
/*
.tabbrowser-tab[selected]:not([pinned]) .tab-label-container, .tabbrowser-tab:not([pinned]) {
	padding-inline-end: 6px !important;
}
*/

.tab-icon-stack {
	margin-inline-start: auto
}

.tab-label-container {
	max-width: min-content;
	margin-inline-end: auto;
}

/* Increase minimum tab width */
.tabbrowser-tab {
	min-width: 125px !important;
}

/* Change tab decorations */
.tab-background {
	background: transparent !important;
	border: none !important;
	box-shadow: none !important;
	border-radius: 4px !important;
}

.tab-label {
	color: var(--fg-color) !important;
	font-weight: 500 !important;
}

/* Selected tab decorations */
.tabbrowser-tab[selected] .tab-background {
	background: transparent !important;
	border: 1.5px solid var(--accent-color) !important;
	box-shadow: none !important;
	border-radius: 5px !important;
}

.tabbrowser-tab[selected] .tab-label {
	color: var(--accent-color) !important;
	font-weight: 700 !important;
}

/* Dimmed urlbar scheme */
.urlbar-input .text-link{
	color: #ff0000 !important;
}

.urlbar-input-box .urlbar-scheme {
	color: #ff0000 !important;
	font-weight: 400 !important;
}

/* Normal color for real/host part of URL */
.urlbar-input-box .urlbar-domain {
	color: #e8e8e8 !important;
	font-weight: 700 !important;
}

/* Placeholder text */
#urlbar-input::placeholder {
	color: #a5a3a1 !important;
	font-weight: 700 !important;
}

/** End customize address bar **/

/** Customize burger menu **/

/* Hide sync button */
toolbaritem#appMenu-fxa-status2 {
	display: none !important;
}

/* Hide profiles button */
toolbarbutton#appMenu-empty-profiles-button {
	display: none !important;
}

/* Hide ugly gradient separator */
toolbarseparator#appMenu-fxa-separator {
	display: none !important;
}

/* Other separators are not uniquely identified unfortunately */
toolbarseparator {
	display: none !important;
}

/* Hide print button (just use hotkey) */
toolbarbutton#appMenu-print-button2 {
	display: none !important;
}

/* Hide save button (just use hotkey) */
toolbarbutton#appMenu-save-file-button2 {
	display: none !important;
}

/* Hide find button (just use hotkey) */
toolbarbutton#appMenu-find-button2 {
	display: none !important;
}

/* Hide zoom controls (just use hotkeys) */
toolbaritem#appMenu-zoom-controls {
	display: none !important;
}

/* Hide report broken site button */
toolbarbutton#appMenu-report-broken-site-button {
	display: none !important;
}

/* Hide help button */
toolbarbutton#appMenu-help-button2 {
	display: none !important;
}

/* Hide quit button */
toolbarbutton#appMenu-quit-button2 {
	display: none !important;
}

/** End customize burger menu **/

/** Customize (right-click) popup **/

/* Hide useless menu navigation group */
menugroup#context-navigation {
	display: none !important;
}

/* Hide useless select all */
menuitem#context-selectall {
	display: none !important;
}

/* Hide "Inspect Accessibility Properties */
menuitem#context-inspect-a11y {
	display: none !important;
}

/* Hide take screenshot button */
menuitem#context-take-screenshot {
	display: none !important;
}

/* Hide email image button (be fr bruv) */
menuitem#context-sendimage {
	display: none !important;
}

/* Hide bookmark link button */
menuitem#context-bookmarklink {
	display: none !important;
}

/* Hide save link as button */
menuitem#context-savelink {
	display: none !important;
}

/* Hide open link in split view button */
menuitem#context-openlinkinsplitview {
	display: none !important;
}

/* Hide separators */
menuseparator#context-sep-screenshots,
menuseparator#context-sep-selectall, menuseparator#context-sep-navigation {
	display: none !important;
}

menupopup#contentAreaContextMenu menuitem:hover {
	background-color: var(--accent-color) !important;
}

menu[_moz-menuactive="true"] {
	background-color: var(--accent-color) !important;
}

/** End customize popup **/

/* Style history sidebar */
#sidebar-box, #historyTree {
	background-color: var(--bg-color) !important;
	color: var(--fg-color) !important;
}

#search-box {
	--input-text-background-color: var(--lighter-bg-color) !important;
	--input-text-border-color: var(--accent-color) !important;
}

#input {
	outline: none !important;
	padding-right: 0 !important;
}

#viewButton {
	background-color: var(--lighter-bg-color) !important;
	color: var(--fg-color) !important;
	border-color: var(--accent-color) !important;
	border-radius: 8px !important;
	padding: 5px !important;
	margin-top: 0 !important;
	margin-bottom: 0 !important;
}

toolbarbutton#sidebar-close {
	background: none !important;
	outline: none !important;
	border: none !important;
}

toolbarbutton#sidebar-close:active {
	outline: 1px solid var(--accent-color) !important;
	fill: var(--accent-color) !important;
}

